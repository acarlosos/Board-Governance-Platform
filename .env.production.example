# Template produção — copiar para o editor de env do Forge; NUNCA commitar segredos reais.
APP_NAME="Board Governance Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.example.com

QUEUE_CONNECTION=database
CACHE_STORE=database

# Dashboard executivo (ver docs/features/dashboard.md)
# BGP_DASHBOARD_USE_EXECUTIVE_WIDGETS=false
# BGP_DASHBOARD_USE_PROJECTION=false

# Backup Spatie (quando pacote compatível Laravel 13 estiver instalado — ver docs/execution/18-production-deploy.result.md)
# BACKUP_DISK=local
