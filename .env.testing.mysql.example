# Board Governance Platform — smoke de testes contra MySQL (17.7)
#
# Uso:
#   cp .env.testing.mysql.example .env.testing.mysql
#   # Ajustar DB_* ao teu servidor ou container (ex.: Docker mysql:8).
#   vendor/bin/phpunit -c phpunit.mysql.xml
#   # ou: php artisan test --configuration=phpunit.mysql.xml
#
# APP_ENV tem de ser exactamente "testing.mysql" (ficheiro .env.testing.mysql + phpunit.mysql.xml).

APP_NAME=Laravel
APP_ENV=testing.mysql
APP_KEY=base64:6pWym7V0dDtO8ExEr89h+RscAugcTR6VghGUTO5Qarc=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# Obrigatório: impede correr MySQL smoke sem intenção explícita (ver tests/TestCase.php).
TESTING_MYSQL_SMOKE=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bgp_smoke_test
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
MAIL_MAILER=array
